#!/bin/sh
# Impede push de commits com assinatura Cursor (ex.: fork desatualizado).
pattern='Co-authored-by:.*[Cc]ursor|Made-with:.*[Cc]ursor|Made with Cursor|cursoragent@cursor\.com'
while read local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "0000000000000000000000000000000000000000" ] && continue
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    range="$local_sha"
  else
    range="${remote_sha}..${local_sha}"
  fi
  if git log "$range" --format=%B 2>/dev/null | grep -qiE "$pattern"; then
    echo "pre-push: commit com assinatura Cursor detectado. Amend/rebase antes do push."
    exit 1
  fi
done
exit 0
