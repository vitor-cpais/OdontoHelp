# Copie para .env na raiz do projeto:  copy .env.example .env
# Nunca commite o arquivo .env (está no .gitignore).

POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=altere-senha-postgres-local
POSTGRES_PORT=5432

BACKEND_PORT=8080
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Gere uma chave forte (ex.: PowerShell):
#   [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
JWT_SECRET=altere-esta-chave-base64-antes-de-subir

APP_ADMIN_EMAIL=admin@odonto.com
APP_ADMIN_PASSWORD=altere-senha-admin-local
