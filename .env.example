# =============================================================================
# DESENVOLVIMENTO LOCAL — copie:  copy .env.example .env
# Opcional: sem .env o Docker usa os padroes do docker-compose.yml
# =============================================================================

POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgrespw
POSTGRES_PORT=5432

BACKEND_PORT=8080
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
APP_FRONTEND_URL=http://localhost:5173

# Remova a linha JWT_SECRET abaixo para usar o padrao do Docker (dev).
# Se definir, use Base64 com 32+ bytes (senao login falha com WeakKeyException).
# JWT_SECRET=

APP_ADMIN_EMAIL=admin@odonto.com
APP_ADMIN_PASSWORD=123456

# Recuperacao de senha: em dev, false grava o link no log do backend.
APP_MAIL_ENABLED=false
APP_MAIL_FROM=no-reply@odontohelp.local
SPRING_MAIL_HOST=localhost
SPRING_MAIL_PORT=1025
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_SMTP_AUTH=false
SPRING_MAIL_SMTP_STARTTLS=false
