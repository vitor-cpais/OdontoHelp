# Dominios via .env: FRONTEND_DOMAIN e API_DOMAIN (ex. DuckDNS)
# Caddy obtem certificado Let's Encrypt automaticamente.

{$FRONTEND_DOMAIN} {
	reverse_proxy frontend:80
}

{$API_DOMAIN} {
	@internal path /internal/*
	respond @internal 403

	rate_limit {
		zone auth {
			match {
				path /auth/*
			}
			key {remote_host}
			events 10
			window 1m
		}
		zone api {
			key {remote_host}
			events 120
			window 1m
		}
	}

	# Financeiro no mesmo host (ex. DuckDNS sem 3o subdominio). Paths /financeiro/* nao existem no Core.
	handle /financeiro* {
		reverse_proxy financeiro:8081
	}
	handle {
		reverse_proxy backend:8080
	}
}

# Subdominio dedicado (opcional — descomente quando existir no DNS):
# financeiro-api-odontohelp.duckdns.org {
# 	reverse_proxy financeiro:8081
# }
